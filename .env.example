# Copy to .env on the Pi Zero 2W and adjust to match your I2S card.
# List devices:  arecord -l  (capture)  and  aplay -l  (playback)
#
# Unlike the Pi 5 (USB cards), the Zero 2W uses a GPIO I2S mic + I2S class-D
# amp. With a single I2S sound card (e.g. googlevoicehat-soundcard overlay),
# capture and playback are usually the SAME card number. Confirm with -l.

# I2S microphone (find card number in `arecord -l`)
AUDIO_INPUT_DEVICE=plughw:0,0

# I2S class-D amp / speaker (find card number in `aplay -l`)
AUDIO_OUTPUT_DEVICE=plughw:0,0

# Mic calibration at session start: quiet period, then speaker says "Say hello to start"
CALIBRATION_QUIET_SEC=1.0
CALIBRATION_SPEAK_SEC=5.0

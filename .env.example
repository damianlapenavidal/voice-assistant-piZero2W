# Copy to .env on the Pi Zero 2W and adjust to match your I2S card.
# List devices:  arecord -l  (capture)  and  aplay -l  (playback)
#
# Unlike the Pi 5 (USB cards), the Zero 2W uses a GPIO I2S mic + I2S class-D
# amp. With a single I2S sound card (e.g. googlevoicehat-soundcard overlay),
# capture and playback are usually the SAME card number. Confirm with -l.

# I2S microphone (find card number in `arecord -l`)
AUDIO_INPUT_DEVICE=plughw:0,0

# I2S class-D amp / speaker (find card number in `aplay -l`)
AUDIO_OUTPUT_DEVICE=plughw:0,0

# Mic calibration at session start: quiet period, then speaker says "Say hello to start"
CALIBRATION_QUIET_SEC=1.0
CALIBRATION_SPEAK_SEC=5.0

# Software gain. The mic's raw signal is quiet by hardware design (fixed
# sensitivity), so make-up gain is applied here as a steady multiplier -- not
# per-chunk normalization, which would pump the noise floor between words.
# Both are hard-clipped to prevent wraparound distortion if pushed too high.
# Start at 1.0 and raise gradually; verify with:
#   python audio-diagnostic equivalent: record, check for clipping, repeat.
INPUT_GAIN=1.0

# 0.35 was the comfortable level found during manual SoX testing with this
# speaker/amp combination. Treat it as a starting point for THIS hardware,
# not a universal value -- raise or lower by ear.
PLAYBACK_GAIN=0.35
